// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── Auth Models ───

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String?
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    password      String?
    role          String    @default("student") // student, admin
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    accounts          Account[]
    sessions          Session[]
    posts             Post[]
    studentHighlights StudentHighlight[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─── Content Models ───

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

model Service {
    id          String   @id @default(cuid())
    title       String
    description String
    status      String   // Available, Coming Soon, Beta, In Development
    icon        String?
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

model TrainingRound {
    id          String   @id @default(cuid())
    name        String
    slug        String   @unique
    description String?
    status      String   @default("active") // active, upcoming, completed
    startDate   DateTime?
    endDate     DateTime?
    priceEGP    Float?
    priceUSD    Float?
    isCurrent   Boolean  @default(false)
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    highlights       StudentHighlight[]
    courseSections   CourseSection[]
}

model StudentHighlight {
    id          String   @id @default(cuid())
    studentName String
    photoUrl    String?
    category    String   // top_quiz, top_task, session_answer, community_contributor, interviewed, exam_performer, top_student
    description String?
    rank        String?  // e.g. "1st", "2nd", "3rd", "Top 10"
    roundId     String
    round       TrainingRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
    userId      String?
    user        User?    @relation(fields: [userId], references: [id])
    createdAt   DateTime @default(now())
}

model Testimonial {
    id        String   @id @default(cuid())
    name      String
    role      String?  // e.g. "Student", "Graduate"
    content   String
    avatarUrl String?
    rating    Int?     @default(5)
    featured  Boolean  @default(false)
    order     Int      @default(0)
    createdAt DateTime @default(now())
}

model FAQ {
    id        String   @id @default(cuid())
    question  String
    answer    String
    category  String?  // general, pricing, training, community
    order     Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Announcement {
    id        String   @id @default(cuid())
    title     String
    content   String
    type      String   @default("info") // info, warning, success, event
    active    Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Certificate {
    id          String   @id @default(cuid())
    title       String
    description String?
    imageUrl    String?
    type        String   // html_css, full_training
    priceEGP    Float?
    priceUSD    Float?
    available   Boolean  @default(true)
    createdAt   DateTime @default(now())
}

model CurriculumTopic {
    id          String   @id @default(cuid())
    title       String
    description String?
    icon        String?
    category    String   // core, advanced, tools, career
    order       Int      @default(0)
    duration    String?  // e.g. "2 weeks", "4 weeks"
    topics      String?  // JSON array of subtopics
    pdfUrl      String?  // downloadable PDF
    createdAt   DateTime @default(now())
}

model Setting {
    id    String @id @default(cuid())
    key   String @unique
    value String
}

model SocialLink {
    id   String @id @default(cuid())
    name String
    url  String
    icon String
    order Int @default(0)
}

model Achievement {
    id          String   @id @default(cuid())
    studentName String
    photoUrl    String?
    title       String
    description String?
    date        DateTime @default(now())
    type        String   // success_story, weekly_winner, community_win, interview_highlight, best_contributor
    featured    Boolean  @default(false)
    createdAt   DateTime @default(now())
}

// ─── Course Sections (for image-based achievement categories) ───

model CourseSection {
    id          String   @id @default(cuid())
    name        String   // e.g. "أوائل الاختبارات", "أفضل المساهمين"
    slug        String   // e.g. "quiz-champions", "community-contributors"
    icon        String?  // emoji icon
    description String?
    roundId     String
    round       TrainingRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    images      SectionImage[]

    @@unique([slug, roundId])
}

model SectionImage {
    id        String   @id @default(cuid())
    imageUrl  String
    caption   String?
    order     Int      @default(0)
    sectionId String
    section   CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
}
